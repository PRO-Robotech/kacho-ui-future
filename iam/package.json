{
  "name": "kacho-ui-future-iam",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5177 --host 0.0.0.0 --strictPort",
    "dev:remote:watch": "vite build --watch",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4177 --strictPort",
    "test": "node --no-warnings --experimental-vm-modules ../node_modules/jest/bin/jest.js --runInBand --silent --passWithNoTests --testTimeout=30000",
    "typecheck": "tsc -b --noEmit",
    "check": "npm run lint && npm run format:check",
    "lint": "npm run lint:js && npm run lint:css && npm run typecheck",
    "lint:fix": "npm run lint:js:fix && npm run lint:css:fix && npm run format",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/**/*.{css,scss}\"",
    "lint:css:fix": "stylelint \"src/**/*.{css,scss}\" --fix",
    "format": "prettier . --check",
    "format:check": "prettier . --check",
    "format:write": "prettier . --write"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@tanstack/react-query": "^5.66.0",
    "antd": "^6.3.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.474.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.11",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.1.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
